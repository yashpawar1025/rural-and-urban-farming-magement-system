# Supabase Configuration - Example Template
# Replace with your actual Supabase credentials

# Your Supabase project URL (base URL only, no /rest/v1)
# Get this from: Settings → API → Project URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anonymous/public API key
# Get this from: Settings → API → Project API keys → anon public
VITE_SUPABASE_ANON_KEY=your-api-key-here

# Optional: Project metadata
VITE_PROJECT_NAME=SmartFarm
VITE_PROJECT_ID=your-project-id
